rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocumentOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    function isCreatingOwnDocument() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ─── User Profiles ──────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Prevent accidental deletion
    }

    // ─── Clients ────────────────────────────────────────────────────────────────

    match /clients/{clientId} {
      allow read: if isAuthenticated() && isDocumentOwner();
      allow create: if isCreatingOwnDocument();
      allow update: if isAuthenticated() && isDocumentOwner();
      allow delete: if isAuthenticated() && isDocumentOwner();
    }

    // ─── Cases ──────────────────────────────────────────────────────────────────

    match /cases/{caseId} {
      allow read: if isAuthenticated() && isDocumentOwner();
      allow create: if isCreatingOwnDocument();
      allow update: if isAuthenticated() && isDocumentOwner();
      allow delete: if isAuthenticated() && isDocumentOwner();
    }

    // ─── Hearings ───────────────────────────────────────────────────────────────

    match /hearings/{hearingId} {
      allow read: if isAuthenticated() && isDocumentOwner();
      allow create: if isCreatingOwnDocument();
      allow update: if isAuthenticated() && isDocumentOwner();
      allow delete: if isAuthenticated() && isDocumentOwner();
    }

    // ─── Payments ───────────────────────────────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && isDocumentOwner();
      allow create: if isCreatingOwnDocument();
      allow update: if false; // Payments are immutable — only create
      allow delete: if false; // Never delete payment records
    }

    // ─── Notes ──────────────────────────────────────────────────────────────────

    match /notes/{noteId} {
      allow read: if isAuthenticated() && isDocumentOwner();
      allow create: if isCreatingOwnDocument();
      allow update: if isAuthenticated() && isDocumentOwner();
      allow delete: if isAuthenticated() && isDocumentOwner();
    }

    // ─── Documents ──────────────────────────────────────────────────────────────

    match /documents/{documentId} {
      allow read: if isAuthenticated() && isDocumentOwner();
      allow create: if isCreatingOwnDocument();
      allow update: if false; // Document metadata is immutable
      allow delete: if isAuthenticated() && isDocumentOwner();
    }

  }
}
